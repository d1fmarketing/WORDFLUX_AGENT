    "sse_stream_example": {
      "description": "Server-Sent Events stream connection",
      "request": {
        "method": "GET",
        "url": "/events/stream",
        "notes": "This is an EventSource connection, not a regular HTTP request"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "text/event-stream",
          "Cache-Control": "no-cache",
          "X-Accel-Buffering": "no"
        },
        "body": "data: {\"ts\":1704067200000,\"kind\":\"board_update\",\"column\":\"In Progress\",\"card\":{\"id\":\"c-123\",\"title\":\"Test\"}}\n\ndata: {\"ts\":1704067201000,\"kind\":\"agent_action\",\"card\":{\"id\":\"c-123\"},\"action\":\"start_work\",\"to\":\"In Progress\",\"job_id\":\"job-456\"}\n\n: ping 1704067210\n\n"
      }
    }
  },
  "javascript_examples": {
    "sse_connection": "// Connect to Server-Sent Events stream\nconst eventSource = new EventSource('/events/stream');\n\neventSource.onmessage = (event) => {\n  const data = JSON.parse(event.data);\n  console.log('Event received:', data);\n  \n  switch(data.kind) {\n    case 'board_update':\n      updateBoardUI(data.column, data.card);\n      break;\n    case 'agent_action':\n      showNotification(`Action ${data.action} executed`);\n      break;\n    case 'job_queued':\n      updateJobStatus(data.job_id, 'queued');\n      break;\n  }\n};\n\neventSource.onerror = (error) => {\n  console.error('SSE error:', error);\n  // Reconnection is automatic\n};",
    "execute_action_with_ui_update": "// Execute action and update UI\nasync function executeAction(cardId, action) {\n  try {\n    // Show loading state\n    showSpinner();\n    \n    const response = await fetch('/agent/act', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ card_id: cardId, action: action })\n    });\n    \n    const result = await response.json();\n    \n    if (result.ok) {\n      // Update card position\n      moveCardToColumn(cardId, result.to);\n      \n      // Show job badge\n      addJobBadge(cardId, result.job_id);\n      \n      showNotification(`Job ${result.job_id} queued`);\n    } else {\n      showError(result.error || 'Action failed');\n    }\n  } catch (error) {\n    showError('Network error: ' + error.message);\n  } finally {\n    hideSpinner();\n  }\n}",
    "fetch_kpis_with_chart": "// Fetch KPIs and render chart\nasync function updateKPIChart() {\n  const response = await fetch('/kpis/completed?days=7');\n  const data = await response.json();\n  \n  // Prepare chart data\n  const chartData = {\n    labels: Object.keys(data.by_day),\n    datasets: [{\n      label: 'Completed Tasks',\n      data: Object.values(data.by_day),\n      backgroundColor: '#66d9ef'\n    }]\n  };\n  \n  // Render with Chart.js or similar\n  renderChart('kpi-chart', chartData);\n  \n  // Update summary\n  document.getElementById('total-completed').textContent = data.total;\n}"
  },
