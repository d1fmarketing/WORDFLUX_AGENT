# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# GitHub Configuration
# Personal Access Token from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GitHub repository owner (username or organization)
GITHUB_OWNER=your-username
# GitHub repository name
GITHUB_REPO=your-repo-name

# Queue Configuration
# Options: memory (local development) or redis (production)
QUEUE_MODE=memory
# Full Redis URL (overrides individual settings if provided)
REDIS_URL=redis://localhost:6379/0
# Individual Redis settings (used if REDIS_URL not provided)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Redis key prefix for job queue
REDIS_QUEUE_KEY=wordflux:jobs

# Worker Configuration
# Interval in seconds between job polls
WORKER_POLL_INTERVAL=0.5
# Maximum job execution timeout in seconds
WORKER_TIMEOUT=120

# Cockpit/Webhook Configuration
# URL to post job results back to cockpit
COCKPIT_WEBHOOK_URL=https://your-cockpit.example.com/webhook
# API key for authenticating with cockpit
COCKPIT_API_KEY=your-api-key

# Artifact Storage Configuration (S3-managed encryption)
# AWS region for the artifact bucket
AWS_REGION=us-east-1
# S3 bucket where generated artifacts will be stored
ARTIFACT_BUCKET=wordflux-artifacts-<account>
# Encryption mode: s3 (recommended), kms, auto, none
# - s3: Use S3-managed AES256 encryption (simple, secure, no extra cost)
# - kms: Use customer-managed KMS key (requires ARTIFACT_SSE_KMS_KEY)
# - auto: Use KMS if key is set, otherwise no explicit encryption
# - none: No encryption headers (bucket policy may still encrypt)
ARTIFACT_ENCRYPTION=s3
# KMS key ID or alias (leave empty for S3-managed encryption)
ARTIFACT_SSE_KMS_KEY=
# Presigned URL lifetime in seconds (default: 1 hour)
ARTIFACT_URL_TTL=3600
# Fall back to S3-managed encryption if KMS fails
ARTIFACT_FALLBACK_SSE_S3=true
# Optional custom S3 endpoint (for LocalStack/MinIO in development)
ARTIFACT_S3_ENDPOINT_URL=
# Optional S3 client tuning
S3_MAX_ATTEMPTS=2
S3_CONNECT_TIMEOUT=2
S3_READ_TIMEOUT=5
S3_PUT_DEADLINE_SEC=10

# Environment Settings
# Options: development, staging, production
ENVIRONMENT=development
# Enable debug logging
DEBUG=false
