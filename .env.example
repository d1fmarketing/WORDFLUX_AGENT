# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# GitHub Configuration
# Personal Access Token from https://github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GitHub repository owner (username or organization)
GITHUB_OWNER=your-username
# GitHub repository name
GITHUB_REPO=your-repo-name

# Queue Configuration
# Options: memory (local development) or redis (production)
QUEUE_MODE=memory
# Full Redis URL (overrides individual settings if provided)
REDIS_URL=redis://localhost:6379/0
# Individual Redis settings (used if REDIS_URL not provided)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Redis key prefix for job queue
REDIS_QUEUE_KEY=wordflux:jobs

# Worker Configuration
# Interval in seconds between job polls
WORKER_POLL_INTERVAL=0.5
# Maximum job execution timeout in seconds
WORKER_TIMEOUT=120

# Cockpit/Webhook Configuration
# URL to post job results back to cockpit
COCKPIT_WEBHOOK_URL=https://your-cockpit.example.com/webhook
# API key for authenticating with cockpit
COCKPIT_API_KEY=your-api-key

# Operator API Key (for audit endpoint access)
# This key is required to access the /audit/tail and /audit/tail/text endpoints
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WF_OPERATOR_API_KEY=your-secure-operator-api-key-here

# Artifact Storage Configuration (S3-managed encryption)
# AWS region for the artifact bucket
AWS_REGION=us-east-1
# S3 bucket where generated artifacts will be stored
ARTIFACT_BUCKET=wordflux-artifacts-<account>
# Encryption mode: s3 (recommended), kms, auto, none
# - s3: Use S3-managed AES256 encryption (simple, secure, no extra cost)
# - kms: Use customer-managed KMS key (requires ARTIFACT_SSE_KMS_KEY)
# - auto: Use KMS if key is set, otherwise no explicit encryption
# - none: No encryption headers (bucket policy may still encrypt)
ARTIFACT_ENCRYPTION=s3
# KMS key ID or alias (leave empty for S3-managed encryption)
ARTIFACT_SSE_KMS_KEY=
# Presigned URL lifetime in seconds (default: 1 hour)
ARTIFACT_URL_TTL=3600
# Fall back to S3-managed encryption if KMS fails
ARTIFACT_FALLBACK_SSE_S3=true
# Optional custom S3 endpoint (for LocalStack/MinIO in development)
ARTIFACT_S3_ENDPOINT_URL=
# Optional S3 client tuning
S3_MAX_ATTEMPTS=2
S3_CONNECT_TIMEOUT=2
S3_READ_TIMEOUT=5
S3_PUT_DEADLINE_SEC=10

# Environment Settings
# Options: development, staging, production
ENVIRONMENT=development
# Enable debug logging
DEBUG=false

# LLM Provider Configuration
# Choose between Bedrock (AWS) or Anthropic Direct API
# Default: bedrock (recommended for production with IAM roles)
WF_LLM_PROVIDER=bedrock

# System Prompt Version
# Options: v1_assistive, v2_direct_enhanced, v3_ultrashort, v4_bedrock
# v4_bedrock: Ultra-short, direct PT-BR prompt for Bedrock (recommended)
WF_SYSTEM_PROMPT_VERSION=v4_bedrock

# Chat Agent Configuration - Anthropic & AWS Bedrock
# The system supports two LLM providers for chat functionality:
# 1. Anthropic Direct API (via get_anthropic_client)
# 2. AWS Bedrock (via get_bedrock_client)

# === ANTHROPIC DIRECT API ===
# Get your API key from: https://console.anthropic.com

# REQUIRED (if using Anthropic Direct): Anthropic API Key
# This is required for chat functionality - no default or fallback
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# OPTIONAL: Anthropic Model
# Default: claude-sonnet-4-5-20250929 (Claude Sonnet 4.5)
# Other options: claude-opus-4, claude-sonnet-4, claude-haiku-4
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# === AWS BEDROCK (Alternative) ===
# Use AWS Bedrock for Claude models via AWS infrastructure
# Requires: boto3>=1.28.0 and valid AWS credentials

# REQUIRED (if using Bedrock): AWS Region
# Already defined above for S3, but also used for Bedrock
# AWS_REGION=us-east-1

# OPTIONAL: Bedrock Model ID or Inference Profile ID
# For models requiring inference profiles (Sonnet 4.5), use profile ID
# Default: us.anthropic.claude-sonnet-4-5-20250929-v1:0 (Claude Sonnet 4.5 via US inference profile)
# Other options:
#   - us.anthropic.claude-sonnet-4-20250514-v1:0 (Sonnet 4 via US profile)
#   - anthropic.claude-3-5-sonnet-20240620-v1:0 (Sonnet 3.5, direct model ID)
# Check: aws bedrock list-inference-profiles --region us-east-1
ANTHROPIC_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Session and Rate Limiting
# Session history TTL in seconds (24 hours)
WF_CHAT_TTL_SEC=86400
# Rate limit: max requests per minute per IP
WF_RATELIMIT_PER_MIN=20
# Token input cap: max input tokens per request (prevents cost explosions)
# Recommended: 8000 for Claude Sonnet (leaves room for system prompt + history)
# Note: This is a soft limit based on rough estimation, not exact tokenization
WF_TOKEN_INPUT_CAP=8000

# === CONTENT QUALITY AGENTS ===

# Link Validator Configuration
# Timeout for URL validation requests (seconds)
LINK_VALIDATOR_TIMEOUT=10
# Maximum number of redirects to follow
LINK_VALIDATOR_MAX_REDIRECTS=3
# Cache TTL for validation results (seconds, default: 1 hour)
LINK_VALIDATOR_CACHE_TTL=3600
# Minimum pass score (0-100, default: 95)
LINK_VALIDATOR_MIN_SCORE=95

# SEO Analyzer Configuration
# Meta title length requirements (characters)
SEO_MIN_TITLE_LENGTH=30
SEO_MAX_TITLE_LENGTH=60
# Meta description length requirements (characters)
SEO_MIN_DESC_LENGTH=120
SEO_MAX_DESC_LENGTH=160
# Minimum SEO score to pass (0-100, default: 70)
SEO_MIN_SCORE=70
# Target keyword density percentage (default: 1.5%)
SEO_TARGET_KEYWORD_DENSITY=1.5
